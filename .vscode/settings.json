{
    // Python Configuration
    "python.defaultInterpreterPath": "d:/Python Password Menager/.venv/Scripts/python.exe",
    "python.terminal.activateEnvironment": true,
    
    // Linting (Code Quality Checks)
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": true,
    "python.linting.pylintArgs": [
        "--disable=C0111",  // Missing docstring (we have plenty!)
        "--disable=C0103",  // Invalid name (some short vars are fine)
        "--max-line-length=100"
    ],
    
    // Formatting
    "python.formatting.provider": "autopep8",
    "editor.formatOnSave": true,
    "editor.formatOnPaste": false,
    
    // Editor Visual Settings
    "editor.rulers": [80, 100],
    "editor.wordWrap": "off",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": true,
    
    // File Management
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/.venv": true,
        "**/.password_manager": true
    },
    
    // Type Checking
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.diagnosticMode": "workspace",
    
    // Terminal Settings
    "terminal.integrated.env.windows": {
        "PYTHONPATH": "${workspaceFolder}",
        "FORCE_COLOR": "1"
    },
    "terminal.integrated.env.linux": {
        "PYTHONPATH": "${workspaceFolder}",
        "FORCE_COLOR": "1"
    },
    "terminal.integrated.env.osx": {
        "PYTHONPATH": "${workspaceFolder}",
        "FORCE_COLOR": "1"
    },
    
    // Git Integration
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    
    // Breadcrumbs
    "breadcrumbs.enabled": true,
    
    // Minimap
    "editor.minimap.enabled": true,
    "editor.minimap.maxColumn": 100,
    
    // Suggestions
    "editor.suggestSelection": "first",
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": false
    },
    
    // Security - Don't track sensitive files
    "files.watcherExclude": {
        "**/.password_manager/**": true,
        "**/backups/**": true,
        "**/*.enc": true,
        "**/*.key": true
    }
}
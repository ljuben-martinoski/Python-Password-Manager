# ============================================================================
# Password Manager .gitignore
# Place this file in your project root directory
# ============================================================================

# ============================================================================
# CRITICAL - NEVER COMMIT THESE FILES!
# ============================================================================

# Your encrypted password data (MOST IMPORTANT!)
.password_manager/
*.enc
*.key
backups/
*.backup

# Environment variables that might contain secrets
.env
.env.local
.env.*.local

